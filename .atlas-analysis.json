  "keyFeatures": [
    "Fast parallel repository scanning using Rust and rayon",
    "Detects uncommitted changes and local-only repositories",
    "Configurable depth and filtering options",
    "Raw output mode for scripting and piping",
    "Unpushed commits tracking (ahead of upstream)"
  ],
  "publicApiSurface": [
    "dirty <path> - Scan directory for git repositories",
    "--depth/-L <n> - Set maximum directory depth (default: 3)",
    "--dirty/-d - Show only repositories with uncommitted changes",
    "--local/-l - Show only repositories with no remotes",
    "--include-unpushed/-u - Include unpushed commit information",
    "--raw/-r - Output raw paths for piping"
  ]
}
